{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,
  "mcp": {
    "tailwindcss-mcp": {
      "type": "local",
      "command": ["pnpm", "dlx", "tailwindcss-mcp-server@latest"],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["pnpm", "dlx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "hugeicons": {
      "type": "local",
      "command": ["pnpm", "dlx", "@hugeicons/mcp-server"],
      "enabled": true
    }
  }
}
